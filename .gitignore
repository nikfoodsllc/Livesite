# Ignore ALL dot files by default
.*

# EXCEPTIONS - Track these specific dot files
!.gitignore
!.env.bak

# TDN9IL - Next.js TypeScript Project .gitignore
# Technology Stack: Next.js, TypeScript, pnpm
# =============================================================================
# DEPENDENCIES
# pnpm
node_modules
.pnpm-store
.pnpm-debug.log*
# npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Package manager files
.pnp
.pnp.*
# NEXT.JS BUILD OUTPUTS
# Next.js build output
.next/
out/
build/
# Next.js temporary files
.next/cache/
.next/static/chunks/
# TYPESCRIPT & DEVELOPMENT
# TypeScript
*.tsbuildinfo
next-env.d.ts
# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
# ENVIRONMENT & CONFIGURATION
# Environment variables (keep only examples)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Keep these environment files (remove if not needed)
!.env.example
!.env.template
# TESTING & COVERAGE
# Test coverage
coverage/
.nyc_output/
lcov-report/
# Test artifacts
*.lcov
test-results/
playwright-report/
test-results.xml
# LOGS & TEMPORARY FILES
# Logs
logs
*.log
pnpm-debug.log*
lerna-debug.log*
# Runtime data
pids
*.pid
*.seed
*.pid.lock
# Temporary files
tmp/
temp/
.tmp/
# DEPLOYMENT & PRODUCTION
# Vercel
.vercel
# Netlify
.netlify
# AWS
.aws/
# SECURITY & CERTIFICATES
# SSL certificates
*.pem
*.key
*.crt
*.csr
# Security and secrets
.envrc
.secrets
private/
config/secrets/
# BUNDLER & TOOLS
# Webpack
.webpack/
# ESLint
.eslintcache
# Prettier
.prettierignore
.prettiercache
# Stylelint
.stylelintcache
# ANALYSIS & PERFORMANCE
# Bundle analysis
.analyze
bundle-analyzer-report.html
# Performance monitoring
.esbuild
# DOCUMENTATION & REPORTS
# Generated documentation
docs/build/
# Coverage badges
coverage-badges/
# Test reports
*.tap
junit.xml
# SPECIFIC TO THIS PROJECT (custom patterns)
# Add any project-specific patterns here
# For example:
# uploads/
# cache/
# public/temp/
# EXCEPTIONS - FILES TO TRACK
# Keep important dot files despite the .* rule below
!.gitattributes
!.prettierrc*
!.eslintrc*
!.editorconfig
# CATCH-ALL (use with caution)
# Uncomment if you want to ignore ALL dot files by default
# !.*